# Build output
/build/bin/
/dist/
/SHA256SUMS

# Frontend build artifacts and deps
/frontend/node_modules/
/frontend/dist/*
!/frontend/dist/.gitkeep

# Generated Wails bindings are committed (marked generated, regenerated by
# `task generate`) so a fresh checkout type-checks without the Wails CLI; CI
# verifies they are not stale.

# Local environment
*.local
.DS_Store

# Go
*.test
*.out
/coverage.txt

# Wails frontend change-detection cache
/frontend/package.json.md5
